/*

Takes as input a permutation group G. Outputs a list of triple of involutions. Process 9939.

*/

function IsNew(G, geometries, geometry)
        rgeom:= Reverse(geometry);
        for x in geometries do
                g:=sub<G|x>;
                if IsHomomorphism(g,g,geometry) or IsHomomorphism(g,g,rgeom) then
                        return false;
                end if;
        end for;
        return true;
end function;

function HasDualityAndTriality(G, geometry)
        g:=sub<G|geometry>;
        dualGeom:=[geometry[1], geometry[3], geometry[2]];
        if IsHomomorphism(g,g,dualGeom) then // il y a une dualité
                return true;
        else
                return false;
        end if;
end function;

t := Cputime();

load "ON.txt";

Syl := SylowSubgroup(G,3);
z := Random({g : g in Syl | Order(g) eq 3});

x := G.1;
CC := Centralizer(G,x);
P := TransversalProcess(G,CC);
geometries := [];
a := 0;

while (TransversalProcessRemaining(P) gt 0) do
 t1 := Cputime(t);

  g := TransversalProcessNext(P);
  
  p := x^g;
  hp:=z*p*z^(-1);
  hhp:=z^2*p*z^(-2);
        if (sub<G | p, hp, hhp> eq G) then
                G1 := sub<G | hp, hhp >;
                G2 := sub<G | p, hhp >;
                G3 := sub<G | hp, p >;
                if (#(G1 meet G2 meet G3) eq 1) then
                        if (#(G1 meet G2) eq 2) and (#(G1 meet G3) eq 2) and (#(G2 meet G3) eq 2) then
                          if #(Set(G1) meet Set(G3*G2)) eq 4 then
                                  if IsNew(G,geometries,[p,hp,hhp]) and not(HasDualityAndTriality(G, [p,hp,hhp])) then
                                          Append(~geometries, [p,hp,hhp]);
                                  end if;
                          end if;
                        end if;
                end if;
        end if;
        t1 - t;
end while;

